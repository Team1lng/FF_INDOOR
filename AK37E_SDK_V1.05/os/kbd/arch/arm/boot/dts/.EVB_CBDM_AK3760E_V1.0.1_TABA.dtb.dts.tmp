&uart0 {
    pinctrl-names = "default";
    pinctrl-0 = <&uart0_pins>;
    status = "okay";
};

&uart2 {
    pinctrl-names = "default";
    pinctrl-0 = <&uart2_pins>;
    status = "okay";
};

&watchdog {

    def_heartbeat = <10>;
    status = "okay";
};

&rtc {




    osc-select = <0>;
    adjust-time = <0>;
    adjust-based-on-timer;
    status = "okay";
};

&i2c2 {
    pinctrl-names = "default","sleep";
    pinctrl-0 = <&i2c2_pins>;
    pinctrl-1 = <&i2c2_sleep_pins>;

    clock-frequency = <400000>;
    sda-delay = <100>;
    status = "okay";
