    pinctrl-1 = <&i2c4_sleep_pins>;




    gpios = <&gpio 31 0
             &gpio 30 0
            >;

    i2c-gpio,delay-us = <1>;
    status = "okay";

    sensor0: camera@0x45{
        compatible = "anyka,sensor0";
        reg = <0x45>;
        pinctrl-names = "default";
        pinctrl-0 = <&sensor0_reset_pins>;



        reset-gpio = <&gpio 0xFFFF 1>;

        port {
            sensor0_0: endpoint@0 {
                remote-endpoint = <&vi_0_0>;
            };
        };
    };

